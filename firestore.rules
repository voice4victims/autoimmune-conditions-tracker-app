rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function hasProviderAccess(childId) {
      return exists(/databases/$(database)/documents/provider_sessions/$(request.auth.uid))
        && get(/databases/$(database)/documents/provider_sessions/$(request.auth.uid)).data.child_id == childId
        && get(/databases/$(database)/documents/provider_sessions/$(request.auth.uid)).data.expires_at > request.time;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /push_tokens/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /user_consents/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create, update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.parentConsent == true
        && request.resource.data.hipaaConsent == true
        && request.resource.data.consentVersion is string;
    }

    match /children/{childId} {
      allow read: if request.auth != null && (
        resource.data.userId == request.auth.uid ||
        hasProviderAccess(childId)
      );
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId", "createdAt"]) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;

      match /{collection}/{document} {
        allow read: if request.auth != null && (
          get(/databases/$(database)/documents/children/$(childId)).data.userId == request.auth.uid ||
          hasProviderAccess(childId)
        );
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/children/$(childId)).data.userId == request.auth.uid;
      }
    }

    match /privacy_settings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /family_access/{accessId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.owner_user_id ||
         request.auth.uid == resource.data.user_id);
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.owner_user_id;
    }

    match /family_invitations/{inviteId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.invited_by ||
         request.auth.uid == resource.data.invited_user_id);
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["invited_by", "created_at"]) && request.resource.data.invited_by == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.invited_by == request.auth.uid;
    }

    match /symptoms/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /vital_signs/{docId} {
      allow read: if request.auth != null && (
        resource.data.user_id == request.auth.uid ||
        hasProviderAccess(resource.data.child_id)
      );
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "created_at"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /medical_visits/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "created_at"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /medication_reminders/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "created_at"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /notes/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "created_at"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /recipes/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /supplement_recipes/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "created_at"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /food_diary/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "created_at"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /symptom_ratings/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /file_uploads/{docId} {
      allow read: if request.auth != null && (
        resource.data.user_id == request.auth.uid ||
        hasProviderAccess(resource.data.child_id)
      );
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "created_at"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /magic_links/{linkId} {
      allow read: if request.auth != null && (
        resource.data.created_by == request.auth.uid ||
        (resource.data.is_active == true
         && resource.data.expires_at > request.time
         && (resource.data.max_access_count == null || resource.data.access_count < resource.data.max_access_count))
      );
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["created_by", "created_at"]) && request.resource.data.created_by == request.auth.uid;
      allow update: if request.auth != null && (
        resource.data.created_by == request.auth.uid ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['access_count', 'last_accessed'])
      );
      allow delete: if request.auth != null && resource.data.created_by == request.auth.uid;
    }

    match /magic_link_access/{accessId} {
      allow read: if request.auth != null && resource.data.provider_uid == request.auth.uid;
      allow create: if request.auth != null;
    }

    match /provider_sessions/{uid} {
      allow read, create: if request.auth != null && request.auth.uid == uid;
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    match /provider_access_audit/{docId} {
      allow read, write: if false;
    }

    match /rate_limits/{docId} {
      allow read, write: if false;
    }

    match /privacy_audit_logs/{logId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId", "timestamp"]) && request.resource.data.userId == request.auth.uid;
    }

    match /hipaa_audit_logs/{logId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "timestamp"]) && request.resource.data.user_id == request.auth.uid;
    }

    match /activity_logs/{logId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId", "created_at"]) && request.resource.data.userId == request.auth.uid;
    }

    match /audit_failures/{docId} {
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId", "timestamp"]) && request.resource.data.userId == request.auth.uid;
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /deletion_requests/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId"]) && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /deletion_confirmations/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId"]) && request.resource.data.userId == request.auth.uid;
    }

    match /user_sessions/{sessionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId", "createdAt"]) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /session_security_events/{eventId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId", "timestamp"]) && request.resource.data.userId == request.auth.uid;
    }

    match /provider_access/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId"]) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /healthcare_providers/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "created_at"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /temporary_access/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId"]) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /access_reviews/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id"]) && request.resource.data.user_id == request.auth.uid;
      allow update: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /breach_notifications/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId"]) && request.resource.data.userId == request.auth.uid;
    }

    match /risk_assessments/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId"]) && request.resource.data.userId == request.auth.uid;
    }

    match /allergy_records/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "created_at"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /patient_profiles/{docId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["userId"]) && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    match /insurance_info/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /trigger_events/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "created_at"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /medical_records/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id", "created_at"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /treatments/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }

    match /activities/{docId} {
      allow read: if request.auth != null && resource.data.user_id == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.keys().hasAll(["user_id"]) && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.user_id == request.auth.uid;
    }
  }
}
